# Google Sheets
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_NAME=営業リスト

# Google 認証方式: service_account | oauth （デフォルト: service_account）
GOOGLE_AUTH_TYPE=service_account

# サービスアカウント認証（GOOGLE_AUTH_TYPE=service_account の場合）
GOOGLE_SERVICE_ACCOUNT_KEY=credentials/service-account.json

# OAuth2 認証（GOOGLE_AUTH_TYPE=oauth の場合）
# Google Cloud Console でダウンロードした OAuth2 クライアント認証情報を設定する。
# "sales-pilot auth" を実行してトークンを取得してから使用する。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_TOKEN_PATH=credentials/oauth-token.json
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Gmail（送信者情報）
GMAIL_FROM=your_email@example.com
GMAIL_NAME=あなたの名前

# Meeting URL（日程調整ツール: TimeRex 等）
MEETING_URL=

# Google Maps Places API
GOOGLE_MAPS_API_KEY=

# 送信設定
SEND_INTERVAL_MS=3000
DRY_RUN=false
